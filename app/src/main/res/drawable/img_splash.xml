<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="360dp"
    android:height="640dp"
    android:viewportWidth="360"
    android:viewportHeight="640">

    <!-- Dark Blue Gradient Background -->
    <path
        android:pathData="M0,0h360v640h-360z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="180"
                android:startY="0"
                android:endX="180"
                android:endY="640"
                android:type="linear">
                <item
                    android:color="#0F2027"
                    android:offset="0.0" />
                <item
                    android:color="#203A43"
                    android:offset="0.5" />
                <item
                    android:color="#2C5364"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Circular Avatar Outline -->
    <path
        android:fillColor="#ffffff"
        android:fillAlpha="0.1"
        android:pathData="M180,260m-70,0a70,70 0,1,1 140,0a70,70 0,1,1 -140,0" />

    <!-- Avatar Head -->
    <path
        android:fillColor="#ffffff"
        android:fillAlpha="0.8"
        android:pathData="M180,240m-30,0a30,30 0,1,1 60,0a30,30 0,1,1 -60,0" />

    <!-- Avatar Shoulders -->
    <path
        android:fillColor="#ffffff"
        android:fillAlpha="0.8"
        android:pathData="M180,285c-25,0 -48,12 -58,30c12,18 33,30 58,30s46,-12 58,-30c-10,-18 -33,-30 -58,-30z" />

    <!-- Soft Decorative Curved Wave at the Bottom -->
    <path
        android:pathData="M0,520 Q180,480 360,520 L360,640 L0,640 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="180"
                android:startY="500"
                android:endX="180"
                android:endY="640"
                android:type="linear">
                <item
                    android:color="#3A6073"
                    android:offset="0.0" />
                <item
                    android:color="#16222F"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
