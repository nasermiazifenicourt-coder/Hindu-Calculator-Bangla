<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Set the system window background to solid black -->
        <item name="android:windowBackground">@android:color/black</item>
        
        <!-- On Android 12+ (API 31+), customize the system splash screen to be plain black without any icon -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
    </style>
</resources>
